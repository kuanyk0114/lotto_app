<Lotto539DuplicateScreen>:
    name: 'lotto539_duplicate'
    BoxLayout:
        orientation: 'vertical'
        padding: dp(10)
        spacing: dp(10)
        
        # 標題和返回按鈕
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: dp(40)
            spacing: dp(10)
            
            Button:
                text: '返回'
                font_name: 'ChineseFont'
                size_hint_x: None
                width: dp(60)
                on_press: root.back_to_query()
            
            Label:
                text: '今彩539重複五碼'
                font_name: 'ChineseFont'
                font_size: dp(20)
                bold: True
                size_hint_x: 0.8
                color: get_color_from_hex('#FFC107')
                halign: 'center'
        
        # 說明文字和總筆數
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: dp(30)
            spacing: dp(10)
            
            Label:
                id: total_count_label
                text: '總筆數: 0'
                font_name: 'ChineseFont'
                font_size: dp(12)
                color: get_color_from_hex('#BBBBBB')
                size_hint_x: None
                width: dp(80)
                halign: 'left'
                valign: 'middle'
                text_size: self.size
            
            Label:
                text: '點選重複號碼可查看詳細記錄'
                font_name: 'ChineseFont'
                font_size: dp(12)
                color: get_color_from_hex('#BBBBBB')
                halign: 'center'
                valign: 'middle'
        
        # 重複號碼列表
        ScrollView:
            id: scroll_view
            do_scroll_x: False
            do_scroll_y: True
            
            # 綁定滾動事件檢測
            on_scroll_start: root.on_scroll_start(self, args[1]) if hasattr(root, 'on_scroll_start') else None
            on_scroll_move: root.on_scroll_move(self, args[1]) if hasattr(root, 'on_scroll_move') else None
            on_scroll_stop: root.on_scroll_end(self, args[1]) if hasattr(root, 'on_scroll_end') else None
            
            GridLayout:
                id: duplicate_list
                cols: 1
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(1)


<Lotto539DuplicateDetailScreen>:
    name: 'lotto539_duplicate_detail'
    BoxLayout:
        orientation: 'vertical'
        padding: dp(10)
        spacing: dp(10)
        
        # 標題和返回按鈕
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: dp(40)
            spacing: dp(10)
            
            Button:
                text: '返回'
                font_name: 'ChineseFont'
                size_hint_x: None
                width: dp(60)
                on_press: root.back_to_duplicate()
            
            Label:
                text: '今彩539重複記錄詳情'
                font_name: 'ChineseFont'
                font_size: dp(20)
                bold: True
                size_hint_x: 0.8
                color: get_color_from_hex('#FFC107')
                halign: 'center'
        
        # 詳細記錄列表
        ScrollView:
            id: scroll_view
            do_scroll_x: False
            do_scroll_y: True
            
            # 綁定滾動事件檢測
            on_scroll_start: root.on_scroll_start(self, args[1]) if hasattr(root, 'on_scroll_start') else None
            on_scroll_move: root.on_scroll_move(self, args[1]) if hasattr(root, 'on_scroll_move') else None
            on_scroll_stop: root.on_scroll_end(self, args[1]) if hasattr(root, 'on_scroll_end') else None
            
            GridLayout:
                id: detail_list
                cols: 1
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(5)
                padding: dp(10)

