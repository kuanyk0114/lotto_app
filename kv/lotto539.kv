#:import Animation kivy.animation.Animation
#:import get_color_from_hex kivy.utils.get_color_from_hex


<Lotto539QueryScreen>:
    name: 'lotto539_query'
    BoxLayout:
        orientation: 'vertical'
        padding: dp(10)
        spacing: dp(5)
        
        # 標題區
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: dp(90)  # 標題和說明文字高度
            
            # 主標題
            Label:
                text: '今彩539選號查詢'
                font_name: 'ChineseFont'
                font_size: dp(24)
                bold: True
                size_hint_y: None
                height: dp(35)
                color: get_color_from_hex('#FFC107')
                halign: 'center'
            
            # 說明文字
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: dp(50)
                padding: (dp(5), 0)
                
                Label:
                    text: '可輸入任意球號組合，'
                    font_name: 'ChineseFont'
                    font_size: dp(12)
                    size_hint_y: None
                    height: dp(20)
                    color: get_color_from_hex('#BBBBBB')
                    halign: 'center'
                
                Label:
                    text: '查詢其在歷史開獎獎號中出現的次數及中獎獎別。'
                    font_name: 'ChineseFont'
                    font_size: dp(12)
                    size_hint_y: None
                    height: dp(20)
                    color: get_color_from_hex('#BBBBBB')
                    halign: 'center'
        
        # 主內容區域
        BoxLayout:
            orientation: 'vertical'
            spacing: dp(5)
            size_hint_y: 1  # 佔用剩餘空間
            
            # 號碼網格
            GridLayout:
                id: numbers_grid
                cols: 7
                rows: 6
                spacing: dp(5)
                padding: dp(5)
                size_hint_y: None
                height: dp(264)  # 增加高度，每行約 44dp

            # 添加空白區域確保按鈕不會被擠壓
            Widget:
                size_hint_y: 1
        
        # 固定在底部的功能按鈕區域
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: dp(150)  # 固定高度
            spacing: dp(5)
            
            # 第一行按鈕
            BoxLayout:
                spacing: dp(5)
                size_hint_y: None
                height: dp(45)
                
                Button:
                    text: '取消選取'
                    font_name: 'ChineseFont'
                    font_size: dp(14)
                    background_color: get_color_from_hex('#F44336')
                    on_press: root.clear_selection()
                
                Button:
                    text: '選號查詢'
                    font_name: 'ChineseFont'
                    font_size: dp(14)
                    background_color: get_color_from_hex('#4CAF50')
                    on_press: root.query_history()
            
            # 第二行按鈕
            BoxLayout:
                spacing: dp(5)
                size_hint_y: None
                height: dp(45)
                
                Button:
                    text: '回彩券選擇'
                    font_name: 'ChineseFont'
                    font_size: dp(14)
                    background_color: get_color_from_hex('#9C27B0')
                    on_press: root.manager.current = 'lottery_type'
                
                Button:
                    text: '儲存自選號'
                    font_name: 'ChineseFont'
                    font_size: dp(14)
                    background_color: get_color_from_hex('#2196F3')
                    on_press: root.save_custom_numbers()
                
                Button:
                    text: '提取自選號'
                    font_name: 'ChineseFont'
                    font_size: dp(14)
                    background_color: get_color_from_hex('#FF9800')
                    on_press: root.show_saved_numbers()
            
            # 第三行按鈕
            BoxLayout:
                spacing: dp(5)
                size_hint_y: None
                height: dp(45)
                
                Button:
                    text: '查重複五碼'
                    font_name: 'ChineseFont'
                    font_size: dp(14)
                    background_color: get_color_from_hex('#607D8B')
                    on_press: root.check_duplicates()

                Button:
                    text: '自選號中獎詳情'
                    font_name: 'ChineseFont'
                    font_size: dp(14)
                    background_color: get_color_from_hex('#009688')
                    on_press: root.query_winning_details()

        AdBannerArea:
            id: ad_banner


<Lotto539ResultScreen>:
    name: 'lotto539_result'
    sort_order: 'DESC'
    BoxLayout:
        orientation: 'vertical'
        padding: dp(10)
        spacing: dp(5)

        # Top bar - 仿照大樂透的頂部設計
        BoxLayout:
            size_hint_y: None
            height: dp(40)
            Button:
                text: '返回'
                font_name: 'ChineseFont'
                size_hint_x: 0.2
                on_press: root.back_to_query()
            Label:
                id: title_label
                text: '今彩539查詢結果'
                font_name: 'ChineseFont'
                font_size: dp(20)
                bold: True
                size_hint_x: 0.6
                color: get_color_from_hex('#FFC107')
                halign: 'center'
            Button:
                id: sort_btn
                text: '排序: ' + ('降序' if root.sort_order == 'DESC' else '升序')
                font_name: 'ChineseFont'
                size_hint_x: 0.2
                on_press: root.toggle_sort_order()

        # Selected numbers - 仿照大樂透的自選號顯示
        BoxLayout:
            size_hint_y: None
            height: dp(50)
            padding: (0, dp(5), 0, 0)
            Label:
                text: '自選號：'
                font_name: 'ChineseFont'
                size_hint_x: None
                width: dp(80)
                valign: 'bottom'
            GridLayout:
                id: selected_nums_layout
                cols: 5
                spacing: dp(5)
                size_hint_x: None
                width: self.minimum_width
                pos_hint: {'center_x': 0.5}
                valign: 'bottom'

        # Prize stats - 仿照大樂透的獎別統計設計
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: dp(80)

            # 統計標題
            BoxLayout:
                size_hint_y: None
                height: dp(20)
                padding: (dp(10), 0)
                Label:
                    text: '獎別統計：總筆數'
                    font_name: 'ChineseFont'
                    font_size: dp(14)
                    color: (1, 1, 1, 1)
                    size_hint_x: None
                    width: self.texture_size[0]
                Label:
                    id: total_count_label
                    text: '0'
                    font_name: 'ChineseFont'
                    font_size: dp(14)
                    color: (1, 1, 1, 1)
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.size

            # 統計內容區域
            GridLayout:
                id: prize_stats_layout
                cols: 8
                size_hint_y: None
                height: dp(50)
                spacing: dp(5)
                padding: (dp(10), 0)

                Label:
                    text: '頭獎:'
                    font_name: 'ChineseFont'
                    color: get_color_from_hex('#FFFF00')
                    font_size: dp(14)
                Label:
                    id: prize_count_head
                    text: '0'
                    font_name: 'ChineseFont'
                    color: get_color_from_hex('#FFFF00')
                    font_size: dp(14)
                Label:
                    text: '貳獎:'
                    font_name: 'ChineseFont'
                    color: get_color_from_hex('#FFFF00')
                    font_size: dp(14)
                Label:
                    id: prize_count_second
                    text: '0'
                    font_name: 'ChineseFont'
                    color: get_color_from_hex('#FFFF00')
                    font_size: dp(14)
                Label:
                    text: '參獎:'
                    font_name: 'ChineseFont'
                    color: get_color_from_hex('#FFFF00')
                    font_size: dp(14)
                Label:
                    id: prize_count_third
                    text: '0'
                    font_name: 'ChineseFont'
                    color: get_color_from_hex('#FFFF00')
                    font_size: dp(14)
                Label:
                    text: '肆獎:'
                    font_name: 'ChineseFont'
                    color: get_color_from_hex('#FFFF00')
                    font_size: dp(14)
                Label:
                    id: prize_count_fourth
                    text: '0'
                    font_name: 'ChineseFont'
                    color: get_color_from_hex('#FFFF00')
                    font_size: dp(14)

        # Separator - 分隔線
        Widget:
            size_hint_y: None
            height: dp(1)
            canvas:
                Color:
                    rgba: 0.5, 0.5, 0.5, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

        # Results list - 結果列表
        ScrollView:
            id: scroll_view
            do_scroll_x: False
            do_scroll_y: True
            
            # 綁定滾動事件檢測
            on_scroll_start: root.on_scroll_start(self, args[1]) if hasattr(root, 'on_scroll_start') else None
            on_scroll_move: root.on_scroll_move(self, args[1]) if hasattr(root, 'on_scroll_move') else None
            on_scroll_stop: root.on_scroll_end(self, args[1]) if hasattr(root, 'on_scroll_end') else None
            
            BoxLayout:
                id: results_layout
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(2)
                padding: (dp(5), dp(5))


<Lotto539SavedScreen>:
    name: 'lotto539_saved'
    BoxLayout:
        orientation: 'vertical'
        padding: dp(10)
        spacing: dp(5)
        
        # 標題和返回按鈕
        BoxLayout:
            size_hint_y: None
            height: dp(50)
            
            Button:
                text: '返回'
                font_name: 'ChineseFont'
                size_hint_x: 0.2
                on_press: root.back_to_query()
            
            Label:
                text: '今彩539自選號'
                font_name: 'ChineseFont'
                font_size: dp(24)
                bold: True
                size_hint_x: 0.6
                color: get_color_from_hex('#FFC107')
                halign: 'center'
            
            Label:
                text: f"總數: {len(root.saved_numbers) if root.saved_numbers else 0}"
                font_name: 'ChineseFont'
                size_hint_x: 0.2
        
        # 自選號列表
        ScrollView:
            id: scroll_view
            do_scroll_x: False
            do_scroll_y: True
            
            # 綁定滾動事件檢測
            on_scroll_start: root.on_scroll_start(self, args[1]) if hasattr(root, 'on_scroll_start') else None
            on_scroll_move: root.on_scroll_move(self, args[1]) if hasattr(root, 'on_scroll_move') else None
            on_scroll_stop: root.on_scroll_end(self, args[1]) if hasattr(root, 'on_scroll_end') else None
            
            GridLayout:
                id: saved_list
                cols: 1
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(5)

<Lotto539WinningDetailsScreen>:
    name: 'lotto539_winning_details'
