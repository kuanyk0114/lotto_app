#:import Animation kivy.animation.Animation
#:import get_color_from_hex kivy.utils.get_color_from_hex


<PowerLottoQueryScreen>:
    name: 'power_query'
    BoxLayout:
        orientation: 'vertical'
        padding: dp(10)
        spacing: dp(5)
        
        # 標題區
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: dp(90)  # 標題和說明文字高度
            
            # 主標題
            Label:
                text: '威力彩選號查詢'
                font_name: 'ChineseFont'
                font_size: dp(24)
                bold: True
                size_hint_y: None
                height: dp(160)  # 固定高度 (5行 * 30dp) 原為 dp(160)，調整以適應更大的球
                height: dp(35)
                color: get_color_from_hex('#FFC107')
                halign: 'center'
            
            # 說明文字
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: dp(160)  # 固定高度 (5行 * 30dp) 原為 dp(160)，調整以適應更大的球
                height: dp(50)
                padding: (dp(5), 0)
                
                Label:
                    text: '可輸入任意球號組合，'
                    font_name: 'ChineseFont'
                    font_size: dp(12)
                    size_hint_y: None
                    height: dp(160)  # 固定高度 (5行 * 30dp) 原為 dp(160)，調整以適應更大的球
                    height: dp(20)
                    color: get_color_from_hex('#BBBBBB')
                    halign: 'center'
                
                Label:
                    text: '查詢其在歷史開獎獎號中出現的次數及中獎獎別。'
                    font_name: 'ChineseFont'
                    font_size: dp(12)
                    size_hint_y: None
                    height: dp(160)  # 固定高度 (5行 * 30dp) 原為 dp(160)，調整以適應更大的球
                    height: dp(20)
                    color: get_color_from_hex('#BBBBBB')
                    halign: 'center'
        
        # 主內容區域
        BoxLayout:
            orientation: 'vertical'
            spacing: dp(5)
            size_hint_y: 1  # 佔用剩餘空間
            
            # 第一區標題
            Label:
                text: '第一區 (選1-6個號碼)'
                font_name: 'ChineseFont'
                font_size: dp(16)
                size_hint_y: None
                height: dp(25)
                halign: 'center'
            
            # 第一區號碼網格
            GridLayout:
                id: area1_grid
                cols: 8
                rows: 5
                spacing: dp(5)
                padding: dp(5)
                size_hint_y: None
                height: dp(220)  # 增加高度以提供更大的觸控點（每行約44dp）

            # 添加空白間隔
            Widget:
                size_hint_y: None
                height: dp(15)  # 增加間隔
                     
            # 第二區標題
            Label:
                text: '第二區 (選0-1個號碼)'
                font_name: 'ChineseFont'
                font_size: dp(16)
                size_hint_y: None
                height: dp(25)
                halign: 'center'
            
            # 第二區號碼網格
            GridLayout:
                id: area2_grid
                cols: 8  # 每行8個球
                rows: 1  # 1行
                spacing: dp(5)
                padding: dp(5)
                size_hint_y: None
                height: dp(44)  # 增加高度
            
            # 添加空白區域確保按鈕不會被擠壓
            Widget:
                size_hint_y: 1
        
        # 固定在底部的功能按鈕區域
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: dp(150)  # 固定高度
            spacing: dp(5)
            
            # 第一行按鈕
            BoxLayout:
                spacing: dp(5)
                size_hint_y: None
                height: dp(160)  # 固定高度 (5行 * 30dp) 原為 dp(160)，調整以適應更大的球
                height: dp(45)
                
                Button:
                    text: '取消選取'
                    font_name: 'ChineseFont'
                    font_size: dp(14)
                    background_color: get_color_from_hex('#F44336')
                    on_press: root.clear_selection()
                
                Button:
                    text: '選號查詢'
                    font_name: 'ChineseFont'
                    font_size: dp(14)
                    background_color: get_color_from_hex('#4CAF50')
                    on_press: root.query_history()
            
            # 第二行按鈕
            BoxLayout:
                spacing: dp(5)
                size_hint_y: None
                height: dp(160)  # 固定高度 (5行 * 30dp) 原為 dp(160)，調整以適應更大的球
                height: dp(45)
                
                Button:
                    text: '回彩券選擇'
                    font_name: 'ChineseFont'
                    font_size: dp(14)
                    background_color: get_color_from_hex('#9C27B0')
                    on_press: root.manager.current = 'lottery_type'
                
                Button:
                    text: '儲存自選號'
                    font_name: 'ChineseFont'
                    font_size: dp(14)
                    background_color: get_color_from_hex('#2196F3')
                    on_press: root.save_custom_numbers()
                
                Button:
                    text: '提取自選號'
                    font_name: 'ChineseFont'
                    font_size: dp(14)
                    background_color: get_color_from_hex('#FF9800')
                    on_press: root.show_saved_numbers()
            
            # 第三行按鈕
            BoxLayout:
                spacing: dp(5)
                size_hint_y: None
                height: dp(160)  # 固定高度 (5行 * 30dp) 原為 dp(160)，調整以適應更大的球
                height: dp(45)
                
                Button:
                    text: '查重複六碼'
                    font_name: 'ChineseFont'
                    font_size: dp(14)
                    background_color: get_color_from_hex('#607D8B')
                    on_press: root.check_duplicates()

                Button:
                    text: '自選號中獎詳情'
                    font_name: 'ChineseFont'
                    font_size: dp(14)
                    background_color: get_color_from_hex('#009688')
                    on_press: root.check_winning_details()

        AdBannerArea:
            id: ad_banner

    
<PowerLottoResultScreen>:
    name: 'power_result'
    BoxLayout:
        orientation: 'vertical'
        padding: dp(10)
        spacing: dp(5)
        
        # 標題和返回按鈕
        BoxLayout:
            size_hint_y: None
            height: dp(40)
            
            Button:
                text: '返回'
                font_name: 'ChineseFont'
                size_hint_x: 0.2
                on_press: root.go_back()
            
            Label:
                id: title_label
                text: '威力彩查詢結果'
                font_name: 'ChineseFont'
                font_size: dp(20)
                bold: True
                size_hint_x: 0.6
                color: get_color_from_hex('#FFC107')
                halign: 'center'
            
            Button:
                id: sort_btn
                font_name: 'ChineseFont'
                text: '排序: ' + ('降序' if root.sort_order == 'DESC' else '升序')
                size_hint_x: 0.2
                on_press: root.toggle_sort_order()  # 綁定切換排序方法
        
        # 自選號顯示區域
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: dp(50)
            padding: (0, dp(5), 0, 0)
            spacing: 0
            
            Label:
                text: '自選號:'
                font_name: 'ChineseFont'
                font_size: dp(14)
                size_hint_x: None
                width: dp(60)
                halign: 'left'
                valign: 'bottom'
                text_size: (dp(60), None)
            
            # 自選號顯示容器
            BoxLayout:
                id: selected_nums_layout
                spacing: dp(3)
                size_hint_x: None
                width: self.minimum_width
                valign: 'bottom'
                padding: (0, 0, 0, dp(2))
            
            # 空白區域填充剩餘空間
            Widget:
        
        # 獎別統計和總筆數
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: dp(80)
            
            # 統計標題
            BoxLayout:
                size_hint_y: None
                height: dp(20)
                padding: (dp(10), 0)
                Label:
                    text: '獎別統計：總筆數'
                    font_name: 'ChineseFont'
                    font_size: dp(14)
                    color: (1, 1, 1, 1)
                    size_hint_x: None
                    width: dp(140)
                    halign: 'left'
                    valign: 'middle'
                    text_size: (dp(140), None)
                Label:
                    id: total_count_label
                    text: '0'
                    font_name: 'ChineseFont'
                    font_size: dp(14)
                    color: (1, 1, 1, 1)
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.size

            # 統計內容區域
            GridLayout:
                id: prize_stats_layout
                cols: 8
                size_hint_y: None
                height: dp(50)
                spacing: dp(5)
                padding: (dp(10), 0)

                Label:
                    text: '頭獎:'
                    font_name: 'ChineseFont'
                    color: get_color_from_hex('#FFFF00')
                    font_size: dp(14)
                Label:
                    id: prize_count_head
                    text: '0'
                    font_name: 'ChineseFont'
                    color: get_color_from_hex('#FFFF00')
                    font_size: dp(14)
                Label:
                    text: '貳獎:'
                    font_name: 'ChineseFont'
                    color: get_color_from_hex('#FFFF00')
                    font_size: dp(14)
                Label:
                    id: prize_count_second
                    text: '0'
                    font_name: 'ChineseFont'
                    color: get_color_from_hex('#FFFF00')
                    font_size: dp(14)
                Label:
                    text: '參獎:'
                    font_name: 'ChineseFont'
                    color: get_color_from_hex('#FFFF00')
                    font_size: dp(14)
                Label:
                    id: prize_count_third
                    text: '0'
                    font_name: 'ChineseFont'
                    color: get_color_from_hex('#FFFF00')
                    font_size: dp(14)
                Label:
                    text: '肆獎:'
                    font_name: 'ChineseFont'
                    color: get_color_from_hex('#FFFF00')
                    font_size: dp(14)
                Label:
                    id: prize_count_fourth
                    text: '0'
                    font_name: 'ChineseFont'
                    color: get_color_from_hex('#FFFF00')
                    font_size: dp(14)
                Label:
                    text: '伍獎:'
                    font_name: 'ChineseFont'
                    color: get_color_from_hex('#FFFF00')
                    font_size: dp(14)
                Label:
                    id: prize_count_fifth
                    text: '0'
                    font_name: 'ChineseFont'
                    color: get_color_from_hex('#FFFF00')
                    font_size: dp(14)
                Label:
                    text: '陸獎:'
                    font_name: 'ChineseFont'
                    color: get_color_from_hex('#FFFF00')
                    font_size: dp(14)
                Label:
                    id: prize_count_sixth
                    text: '0'
                    font_name: 'ChineseFont'
                    color: get_color_from_hex('#FFFF00')
                    font_size: dp(14)
                Label:
                    text: '柒獎:'
                    font_name: 'ChineseFont'
                    color: get_color_from_hex('#FFFF00')
                    font_size: dp(14)
                Label:
                    id: prize_count_seventh
                    text: '0'
                    font_name: 'ChineseFont'
                    color: get_color_from_hex('#FFFF00')
                    font_size: dp(14)
                Label:
                    text: '捌獎:'
                    font_name: 'ChineseFont'
                    color: get_color_from_hex('#FFFF00')
                    font_size: dp(14)
                Label:
                    id: prize_count_eighth
                    text: '0'
                    font_name: 'ChineseFont'
                    color: get_color_from_hex('#FFFF00')
                    font_size: dp(14)
                Label:
                    text: '玖獎:'
                    font_name: 'ChineseFont'
                    color: get_color_from_hex('#FFFF00')
                    font_size: dp(14)
                Label:
                    id: prize_count_ninth
                    text: '0'
                    font_name: 'ChineseFont'
                    color: get_color_from_hex('#FFFF00')
                    font_size: dp(14)
                Label:
                    text: '普獎:'
                    font_name: 'ChineseFont'
                    color: get_color_from_hex('#FFFF00')
                    font_size: dp(14)
                Label:
                    id: prize_count_tenth
                    text: '0'
                    font_name: 'ChineseFont'
                    color: get_color_from_hex('#FFFF00')
                    font_size: dp(14)

        
        # 分隔線
        BoxLayout:
            size_hint_y: None
            height: dp(1)
            canvas:
                Color:
                    rgba: get_color_from_hex('#888888')
                Rectangle:
                    pos: self.pos
                    size: self.size
        
        # 結果顯示區域
        ScrollView:
            id: scroll_view
            do_scroll_x: False
            do_scroll_y: True
            
            # 綁定滾動事件檢測
            on_scroll_start: root.on_scroll_start(self, args[1]) if hasattr(root, 'on_scroll_start') else None
            on_scroll_move: root.on_scroll_move(self, args[1]) if hasattr(root, 'on_scroll_move') else None
            on_scroll_stop: root.on_scroll_end(self, args[1]) if hasattr(root, 'on_scroll_end') else None
            
            BoxLayout:
                id: results_layout
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(2)
                padding: (dp(5), dp(5))



<PowerLottoSavedScreen>:
    name: 'power_saved'
    BoxLayout:
        orientation: 'vertical'
        padding: dp(10)
        spacing: dp(5)
        
        # 標題和返回按鈕
        BoxLayout:
            size_hint_y: None
            height: dp(50)
            
            Button:
                text: '返回'
                font_name: 'ChineseFont'
                size_hint_x: 0.2
                on_press: root.back_to_query()
            
            Label:
                text: '威力彩自選號'
                font_name: 'ChineseFont'
                font_size: dp(24)
                bold: True
                size_hint_x: 0.6
                color: get_color_from_hex('#FFC107')
                halign: 'center'
            
            Label:
                text: f"總數: {len(root.saved_numbers)}"
                font_name: 'ChineseFont'
                size_hint_x: 0.2
        
        # 自選號列表
        ScrollView:
            id: scroll_view
            do_scroll_x: False
            do_scroll_y: True
            
            # 綁定滾動事件檢測
            on_scroll_start: root.on_scroll_start(self, args[1]) if hasattr(root, 'on_scroll_start') else None
            on_scroll_move: root.on_scroll_move(self, args[1]) if hasattr(root, 'on_scroll_move') else None
            on_scroll_stop: root.on_scroll_end(self, args[1]) if hasattr(root, 'on_scroll_end') else None
            
            GridLayout:
                id: saved_list
                cols: 1
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(5)

<PowerLottoDuplicateScreen>:
    name: 'power_duplicate'
    BoxLayout:
        orientation: 'vertical'
        padding: dp(10)
        spacing: dp(10)
        
        # 標題和返回按鈕
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: dp(40)
            spacing: dp(10)
            
            Button:
                text: '返回'
                font_name: 'ChineseFont'
                size_hint_x: None
                width: dp(60)
                on_press: root.back_to_query()
            
            Label:
                text: '威力彩重複六碼'
                font_name: 'ChineseFont'
                font_size: dp(20)
                bold: True
                color: get_color_from_hex('#FFC107')
                halign: 'center'
        
        # 說明文字和總筆數
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: dp(30)
            spacing: dp(10)
            
            Label:
                id: total_count_label
                text: '總筆數: 0'
                font_name: 'ChineseFont'
                font_size: dp(12)
                color: get_color_from_hex('#BBBBBB')
                size_hint_x: None
                width: dp(80)
                halign: 'left'
                valign: 'middle'
                text_size: self.size
            
            Label:
                id: hint_label
                text: '點選重複號碼可查看詳細記錄'
                font_name: 'ChineseFont'
                font_size: dp(12)
                color: get_color_from_hex('#BBBBBB')
                halign: 'center'
                valign: 'middle'
        
        # 重複號碼列表
        ScrollView:
            id: scroll_view
            do_scroll_x: False
            on_scroll_start: root.on_scroll_start(self, args[1])
            on_scroll_move: root.on_scroll_move(self, args[1])
            on_scroll_stop: root.on_scroll_end(self, args[1])
            GridLayout:
                id: duplicate_list
                cols: 1
                size_hint_y: None
                height: dp(100)
                spacing: dp(5)

<PowerLottoDuplicateDetailScreen>:
    name: 'power_duplicate_detail'
    BoxLayout:
        orientation: 'vertical'
        padding: dp(10)
        spacing: dp(5)
        
        # 標題和返回按鈕
        BoxLayout:
            size_hint_y: None
            height: dp(40)
            
            Button:
                text: '返回'
                font_name: 'ChineseFont'
                size_hint_x: None
                width: dp(60)
                on_press: root.back_to_duplicate()
            
            Label:
                text: '威力彩重複記錄詳情'
                font_name: 'ChineseFont'
                font_size: dp(24)
                bold: True
                size_hint_x: 0.6
                color: get_color_from_hex('#FFC107')
                halign: 'center'
        
        # 詳細記錄列表
        ScrollView:
            GridLayout:
                id: detail_list
                cols: 1
                size_hint_y: None
                height: dp(160)  # 固定高度 (5行 * 30dp) 原為 dp(160)，調整以適應更大的球
                height: self.minimum_height
                spacing: dp(5)


