                    text: '捌獎:'
                    font_name: 'ChineseFont'
                    color: get_color_from_hex('#FFFF00')
                    font_size: dp(14)
                Label:
                    id: prize_count_eighth
                    text: '0'
                    font_name: 'ChineseFont'
                    color: get_color_from_hex('#FFFF00')
                    font_size: dp(14)
                Label:
                    text: '玖獎:'
                    font_name: 'ChineseFont'
                    color: get_color_from_hex('#FFFF00')
                    font_size: dp(14)
                Label:
                    id: prize_count_ninth
                    text: '0'
                    font_name: 'ChineseFont'
                    color: get_color_from_hex('#FFFF00')
                    font_size: dp(14)
                Label:
                    text: '普獎:'
                    font_name: 'ChineseFont'
                    color: get_color_from_hex('#FFFF00')
                    font_size: dp(14)
                Label:
                    id: prize_count_tenth
                    text: '0'
                    font_name: 'ChineseFont'
                    color: get_color_from_hex('#FFFF00')
                    font_size: dp(14)

        
        # 分隔線
        BoxLayout:
            size_hint_y: None
            height: dp(1)
            canvas:
                Color:
                    rgba: get_color_from_hex('#888888')
                Rectangle:
                    pos: self.pos
                    size: self.size
        
        # 結果顯示區域
        ScrollView:
            id: scroll_view
            do_scroll_x: False
            do_scroll_y: True
            
            # 綁定滾動事件檢測
            on_scroll_start: root.on_scroll_start(self, args[1]) if hasattr(root, 'on_scroll_start') else None
            on_scroll_move: root.on_scroll_move(self, args[1]) if hasattr(root, 'on_scroll_move') else None
            on_scroll_stop: root.on_scroll_end(self, args[1]) if hasattr(root, 'on_scroll_end') else None
            
            BoxLayout:
                id: results_layout
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(2)
                padding: (dp(5), dp(5))



